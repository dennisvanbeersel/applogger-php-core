{
    "name": "applogger/sdk-core",
    "description": "Framework-agnostic PHP error-tracking SDK core for AppLogger (applogger.eu)",
    "type": "library",
    "homepage": "https://applogger.eu",
    "license": "MIT",
    "keywords": [
        "error-tracking",
        "monitoring",
        "logging",
        "psr-18",
        "framework-agnostic"
    ],
    "authors": [
        {
            "name": "Dennis Van Beersel",
            "homepage": "https://applogger.eu"
        }
    ],
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "ext-mbstring": "*",
        "psr/log": "^2|^3",
        "psr/http-client": "^1",
        "psr/http-factory": "^1.1",
        "psr/cache": "^2|^3",
        "psr/clock": "^1",
        "php-http/discovery": "^1.20",
        "nyholm/psr7": "^1.8.2"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.89",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.5",
        "symfony/http-client": "^6.4.6|^7.0",
        "symfony/translation-contracts": "^3.5",
        "symfony/validator": "^7.1"
    },
    "bin": [
        "bin/applogger"
    ],
    "autoload": {
        "psr-4": {
            "ApplicationLogger\\Sdk\\": "src/"
        },
        "files": [
            "src/functions.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "ApplicationLogger\\Sdk\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "phpstan": "phpstan analyse",
        "lint": [
            "@cs-check",
            "@phpstan"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": false
        }
    },
    "support": {
        "issues": "https://github.com/dennisvanbeersel/applogger-php-core/issues",
        "source": "https://github.com/dennisvanbeersel/applogger-php-core"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.0-dev",
            "dev-master": "1.0-dev"
        }
    }
}
