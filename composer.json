{
    "name": "applogger/sdk-core",
    "description": "Framework-agnostic PHP error-tracking SDK core for AppLogger (applogger.eu)",
    "homepage": "https://applogger.eu",
    "license": "MIT",
    "keywords": ["error-tracking", "monitoring", "logging", "psr-18", "framework-agnostic"],
    "authors": [{ "name": "Dennis Van Beersel", "homepage": "https://applogger.eu" }],
    "require": {
        "php": "^8.2",
        "ext-json": "*",
        "ext-mbstring": "*",
        "psr/log": "^1|^2|^3",
        "psr/http-client": "^1",
        "psr/http-factory": "^1",
        "psr/cache": "^2|^3",
        "psr/clock": "^1",
        "php-http/discovery": "^1.19"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "friendsofphp/php-cs-fixer": "^3.89",
        "nyholm/psr7": "^1.8",
        "symfony/http-client": "^6.4|^7.0",
        "symfony/validator": "^6.4|^7.0"
    },
    "bin": ["bin/applogger"],
    "autoload": {
        "psr-4": { "ApplicationLogger\\Sdk\\": "src/" },
        "files": ["src/functions.php"]
    },
    "autoload-dev": {
        "psr-4": { "ApplicationLogger\\Sdk\\Tests\\": "tests/" }
    },
    "scripts": {
        "test": "phpunit",
        "cs-check": "php-cs-fixer fix --dry-run --diff",
        "cs-fix": "php-cs-fixer fix",
        "phpstan": "phpstan analyse",
        "lint": ["@cs-check", "@phpstan"]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": { "php-http/discovery": false }
    },
    "extra": { "branch-alias": { "dev-main": "1.0-dev", "dev-master": "1.0-dev" } }
}
